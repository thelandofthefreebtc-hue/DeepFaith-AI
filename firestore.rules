rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // 0. Default deny
    match /{document=**} {
      allow read, write: if false;
    }

    // Phase 3: Primitives
    function isSignedIn() { return request.auth != null; }
    function isOwner(userId) { return isSignedIn() && request.auth.uid == userId; }
    function isValidId(id) { return id is string && id.size() <= 128; }
    function incoming() { return request.resource.data; }
    function existing() { return resource.data; }

    // User Profile Validation
    function isValidUser(data) {
      return data.uid == request.auth.uid &&
             data.email is string &&
             data.email.size() <= 200 &&
             data.keys().hasAll(['uid', 'email']) &&
             !data.keys().hasAny(['role']); // No self-assigned roles
    }

    match /users/{userId} {
      allow get: if isOwner(userId) && isValidId(userId);
      allow create: if isOwner(userId) && isValidId(userId) && isValidUser(incoming());
      allow update: if isOwner(userId) && isValidId(userId) && isValidUser(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['displayName', 'riskTolerance', 'language', 'worldIdVerified', 'totalBalance', 'updatedAt', 'xp']);
    }

    // Portfolio Validation
    function isValidPortfolio(data) {
      return data.userId == request.auth.uid &&
             data.totalValue is number;
    }

    match /portfolios/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId) && isValidPortfolio(incoming());
      allow update: if isOwner(userId) && isValidPortfolio(incoming()) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['assets', 'totalValue', 'lastUpdated']);
    }

    // Tasks (Public Read, Admin Write - for now just mock admin as system)
    match /tasks/{taskId} {
      allow list, get: if isSignedIn();
      allow write: if false; // Only system via admin SDK or future admin role
    }

    // Progress Tracking
    match /progress/{userId} {
      allow get: if isOwner(userId);
      allow create: if isOwner(userId);
      allow update: if isOwner(userId) &&
                    incoming().diff(existing()).affectedKeys().hasOnly(['completedModules', 'currentLevel', 'xp']);
    }
  }
}
